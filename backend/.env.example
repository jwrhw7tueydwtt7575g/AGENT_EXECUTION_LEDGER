# =============================================================
# .env.example — safe to commit, no real secrets
# Copy to .env and fill real values
# =============================================================

# --- MongoDB Atlas ---
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=agent_ledger

# --- API ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# --- Security (optional in development) ---
API_KEY=
REQUIRE_AUTH_FOR_READS=false
INTERNAL_BROADCAST_KEY=
ALLOWED_PROXY_HOSTS=

# --- Drift Engine ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Anomaly Detector ---
ANOMALY_BASELINE_MIN_RUNS=20

# --- WebSocket ---
WS_EMIT_INTERVAL_SECONDS=2.5
